# API Keys (mindestens einen setzen)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
#DEEPSEEK_API_KEY=   # ggf. schon in Umgebung gesetzt
GROQ_API_KEY=

# Server
LOG_LEVEL=INFO

# Rate Limiting (pro Modell pro 60s)
RATE_LIMIT_MAX_REQUESTS=30

# Cache (in Sekunden)
CACHE_TTL_SECONDS=300

# Budget-Warnung (USD)
BUDGET_WARNING_THRESHOLD=5.0
