# Vetinari — Minimal .env
# At least ONE of the following API keys is required.
# The server will not start without at least one key.

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=

# Optional overrides (defaults are sensible)
# LOG_LEVEL=INFO
# DEFAULT_MODEL=gpt-4o-mini
# DEFAULT_TEMPERATURE=0.7
# MAX_TOKENS=2048
# ENABLE_CACHE=false

# Model fallback chain (comma-separated)
# FALLBACK_MODELS=anthropic/claude-sonnet-4-6,gpt-4o-mini,deepseek/deepseek-chat

# LLM resilience
# LLM_MAX_RETRIES=2
# LLM_RETRY_BASE_DELAY_SECONDS=0.5
# LLM_TIMEOUT_SECONDS=90
# LLM_MAX_CONCURRENT=4

# Input limits (optional)
# MAX_QUERY_CHARS=32000
# MAX_OUTPUT_TOKENS=8192
# MAX_EXPERTS_PER_REQUEST=4
