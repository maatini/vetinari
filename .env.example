# Vetinari — Minimal .env
# At least ONE of the following API keys is required.

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=

# Optional overrides (defaults are sensible)
# LOG_LEVEL=INFO
# DEFAULT_MODEL=gpt-4o-mini
# DEFAULT_TEMPERATURE=0.7
# MAX_TOKENS=2048
# ENABLE_CACHE=false

# LLM resilience (Phase 0+)
# LLM_MAX_RETRIES=2
# LLM_RETRY_BASE_DELAY_SECONDS=0.5
# LLM_TIMEOUT_SECONDS=90
